{
  "rewrites": [
  {
    "source": "/api/movimentacoes",
    "destination": "https://observatorio-backend-fast-api.vercel.app/api/movimentacoes"
  },
  {
    "source": "/api/:path*",
    "destination": "https://observatorio-backend-fast-api.vercel.app/api/:path*"
  },
  {
    "source": "/(.*)",
    "destination": "/index.html"
  }
]
}